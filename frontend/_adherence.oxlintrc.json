{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/Banner/**",
              "components/Button/**",
              "components/Chip/**",
              "components/JrissiGauge/**",
              "components/RoleAvatar/**",
              "components/StatTile/**",
              "src/**",
              "src/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono|Material Symbols Rounded))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono, Material Symbols Rounded."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: tone, icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|warning|danger|success)$/]",
        "message": "<Banner> tone must be one of 'info' | 'warning' | 'danger' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|size|icon|children|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: kind, size, icon, children, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> kind must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: tone, icon, dot, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:low|moderate|high|success|warning|danger|info|neutral)$/]",
        "message": "<Chip> tone must be one of 'low' | 'moderate' | 'high' | 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='JrissiGauge'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|size|key|ref|className|style|children)$/]",
        "message": "<JrissiGauge> doesn't accept that prop. Declared props: score, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|size|style|key|ref|className|style|children)$/]",
        "message": "<RoleAvatar> doesn't accept that prop. Declared props: name, role, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleAvatar'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:doctor|employee|pharmacy|admin)$/]",
        "message": "<RoleAvatar> role must be one of 'doctor' | 'employee' | 'pharmacy' | 'admin'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|unit|delta|deltaTone|style|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: icon, label, value, unit, delta, deltaTone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:good|bad|neutral)$/]",
        "message": "<StatTile> deltaTone must be one of 'good' | 'bad' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
